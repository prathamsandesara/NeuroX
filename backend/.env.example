# Backend Environment Variables Template
# Copy this to .env and update the values for your production environment

# General
PORT=4000
NODE_ENV=production
JWT_SECRET=your-secure-secret-key
FRONTEND_URL=https://your-frontend-domain.com

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://your-neon-user:password@your-neon-endpoint/neondb?sslmode=require&channel_binding=require

# External APIs
GROQ_API_KEY=your-groq-api-key
BREVO_API_KEY=your-brevo-api-key
EMAIL_SENDER_NAME=NeuroX Support
EMAIL_SENDER_ADDR=no-reply@neurox.com
REDIS_URL=redis://localhost:6379

# Services
PISTON_API_URL=https://emkc.org/api/v2/piston/execute
JD_MODEL_URL=http://localhost:5005/parse-jd
INTEGRITY_MODEL_URL=http://localhost:5001/evaluate-integrity
